[Unit]
Description=Uptime Monitor (Docker Compose)
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/amin/Documents/MyProjects/uptime_monitor
# Ensure the full path to docker is correct on your Pi (/usr/bin/docker is typical)
ExecStart=/usr/bin/docker compose up -d --build
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
